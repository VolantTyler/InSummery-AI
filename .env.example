# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# OpenTelemetry GenAI Semantic Conventions (v1.37.0+)
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental

# Enable capturing message content (required for the hook to capture prompts/responses)
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true

# Enable the upload hook to offload large payloads to external storage
OTEL_INSTRUMENTATION_GENAI_COMPLETION_HOOK=upload

# Upload format: 'jsonl' or 'json'
OTEL_INSTRUMENTATION_GENAI_UPLOAD_FORMAT=jsonl

# Upload destination: GCS bucket for production, or a local directory for testing
# Production example: gs://your-telemetry-bucket/gen_ai
# Local development example: ./telemetry_uploads
OTEL_INSTRUMENTATION_GENAI_UPLOAD_BASE_PATH=./telemetry_uploads

# Local CLI: print OpenTelemetry spans to stderr (default: off, keeps demo output clean)
# INSUMMERY_OTEL_CONSOLE=true
